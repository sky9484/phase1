# Labuan Settlement Engine (Splash Labuan Ltd — Labuan FSA Money Broker + DFS)
LABUAN_API_BASE_URL=https://settlement.splash-labuan.internal
LABUAN_API_KEY=
LABUAN_OTC_MIN_USD=10000

# FX Rates (MYR→USD via authorized dealer bank)
MYR_TO_USD_RATE=
FALLBACK_MYR_USD_RATE=0.213

# Intercompany Banking (Maybank KL → Maybank Labuan)
MAYBANK_INTERCOMPANY_ENABLED=true

PHP_PER_USDC=56.5

# Floor / fallback fee used by lib/server/quote.ts only when the target
# currency isn't in lib/fx/corridors.ts. Per-corridor fees (80-110 bps)
# live in lib/fx/corridors.ts and are passed to settlement.move's
# settle_payment / settle_batch as the fee_bps argument.
# Hard ceiling enforced on-chain by MAX_FEE_BPS = 200.
PLATFORM_FEE_BPS=80
FIXED_FEE_SEN=450
QUOTE_TTL_SECONDS=30
DEFAULT_KYC_TIER=1
USDC_AVAILABLE_MICRO=1000000000000000
USDT_AVAILABLE_MICRO=0
USDT_BUFFER_AGE_MS=0
USE_MOCK_APIS=false

SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_LEVEL_NAME=
SUMSUB_BASE_URL=https://api.sumsub.com

ADMIN_EMAIL=staff@splash.finance
ADMIN_PASSWORD=splash-admin-demo
ADMIN_SESSION_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@splash.finance

# ─── AI Copilot ────────────────────────────────────────────────────────────────
# MemWal (Walrus Memory) — privacy-first behavioral memory for the Copilot.
# Server-side ONLY. Set the real values in .env.local (gitignored), never here.
#   MEMWAL_PRIVATE_KEY — delegate Ed25519 private key (hex). SECRET.
#   MEMWAL_ACCOUNT_ID  — Walrus Memory account object ID on Sui (the delegate
#                        key must be registered on this account in the MemWal
#                        dashboard, or the relayer returns 401).
#   MEMWAL_SERVER_URL  — relayer URL (default https://relayer.memory.walrus.xyz).
#   MEMWAL_NAMESPACE   — memory namespace (default "splash-copilot").
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
MEMWAL_NAMESPACE=splash-copilot

# Optional — enables Claude generation in the Copilot. Without it the Copilot
# still works (MemWal recall + grounded domain responses).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
