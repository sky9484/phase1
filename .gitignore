# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# local temp redirect (used when the system temp drive is full)
/.tmp/

# production
/build

# misc
.DS_Store
*.pem

# local dev admin session secret (generated when ADMIN_SESSION_SECRET is unset)
.admin-session-secret.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.testnet.example

# admin-managed runtime config (contract IDs etc.)
/data/contract-config.json
/data/contract-config.json.tmp.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
